# .streamlit/secrets.toml.example
# ─────────────────────────────────────────────────────────────────────────────
# TEMPLATE — safe to commit. Copy to secrets.toml and fill in real values.
# On Streamlit Community Cloud, paste the contents into:
#   App Settings → Secrets
# ─────────────────────────────────────────────────────────────────────────────

[cognicare]
# Use a strong random string — e.g. generated with: python -c "import secrets; print(secrets.token_hex(32))"
secret_salt = "CHANGE_ME_TO_A_STRONG_RANDOM_STRING"

# Demo / seed account — credentials for the auto-seeded demo hospital
demo_hospital_name   = "Your Hospital Name"
demo_clinic_code     = "YOUR-CODE"
demo_doctor_name     = "Dr. Your Name"
demo_doctor_email    = "doctor@yourhospital.com"
demo_doctor_password = "CHANGE_ME_STRONG_PASSWORD"
